{
  "version": "2.0",
  "description": "Regulation tree configuration split across PU's 4 native objects: Regulations & Standards (L1), Regulation Category (L2), Regulation Sub-Category (L3), Provision (L4). Each object gets only the properties relevant to its level.",
  "import_sequence_note": "Import order: L1 first, then L2, L3, L4 — each level references its parent via parent_system_id in the import template.",
  "defaults": {
    "required": false,
    "hidden": false,
    "read_only": false,
    "track_changes": false
  },
  "objects": [
    {
      "object_name": "Regulations & Standards",
      "pu_object_type": "Tree (TR) — Level 1",
      "import_sequence": 2,
      "standard_property_mappings": [
        { "standard_property": "[Name]", "maps_to": "name", "import_column": "Name" },
        { "standard_property": "[Description]", "maps_to": "description", "import_column": "Description" },
        { "standard_property": "[External ID]", "maps_to": "system_id", "import_column": "External ID" }
      ],
      "import_template": {
        "name": "VendorShield - Regulations Import",
        "item_type": "Regulations & Standards",
        "key_column": "External ID",
        "import_options": { "inserts": true, "updates": true },
        "automated_import": true,
        "columns": ["Name", "Description", "External ID", "display_id", "type", "jurisdiction", "issuing_body", "effective_date", "version", "source_url", "status", "scf_mapped", "scf_version", "last_synced_at", "sync_source"]
      },
      "steps": [
